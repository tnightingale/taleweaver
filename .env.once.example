# Once Deployment Environment Variables
# Copy this to .env.once and fill in your actual API keys
# Then reference it when deploying manually if Once loses the config

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

