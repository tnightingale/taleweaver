# =============================================================================
# Taleweaver Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Choose one provider and set its API key
LLM_PROVIDER=groq
# Options: groq (recommended, fast), anthropic (Claude), openai (GPT)

GROQ_API_KEY=your-groq-api-key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Text-to-Speech Configuration (REQUIRED)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ElevenLabs Voice IDs (find at https://elevenlabs.io/app/voice-library)
# Defaults are high-quality pre-selected voices
NARRATOR_VOICE_ID=21m00Tcm4TlvDq8ikWAM
CHARACTER_MALE_VOICE_ID=ErXwobaYiN019PkySvjV
CHARACTER_FEMALE_VOICE_ID=EXAVITQu4vr4xnSDxMaL
CHARACTER_CHILD_VOICE_ID=jBpfuIE2acCO8z3wKNLl

# -----------------------------------------------------------------------------
# Once Platform Variables (AUTO-PROVIDED by Once)
# -----------------------------------------------------------------------------
# These variables are automatically set by the Once deployment platform
# You don't need to set them manually when deploying with Once

# SECRET_KEY_BASE=                # Auto-generated unique identifier
# DISABLE_SSL=false               # Set to true if running without SSL
# SMTP_ADDRESS=                   # Email server address
# SMTP_PORT=587                   # Email server port
# SMTP_USERNAME=                  # Email username
# SMTP_PASSWORD=                  # Email password
# MAILER_FROM_ADDRESS=            # Email from address

# -----------------------------------------------------------------------------
# Storage Paths (OPTIONAL - defaults are Once-compatible)
# -----------------------------------------------------------------------------
# STORAGE_PATH=/storage           # Base storage directory
# JOBS_PATH=/storage/jobs         # Generated audio files
# MUSIC_PATH=/storage/music       # Background music files
